# =============================================================================
#  BhumiDrishti — Backend Environment Configuration
#  Copy this file to .env and adjust values if needed.
#  The defaults work out-of-the-box with docker-compose.
# =============================================================================

# ── Ollama (AI inference) ─────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434

# ── PostgreSQL / PostGIS ──────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bhumidrishti
DB_USER=bhumidrishti
DB_PASSWORD=bhumidrishti
DATABASE_URL=postgresql+asyncpg://bhumidrishti:bhumidrishti@postgres:5432/bhumidrishti

# ── Gemma 4 model selection ───────────────────────────────────────────────────
# e4b  = 4B efficient — fastest, 3-4 GB VRAM  (recommended for demos)
# 12b  = 12B           — balanced quality/speed
# 26b  = 26B           — highest quality,  ~16 GB VRAM
# 31b  = 31B           — highest quality,  ~20 GB VRAM
GEMMA_MODEL=gemma4:e4b
# GEMMA_MODEL=gemma4:26b

# ── Video analysis settings ───────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=300
FRAMES_PER_SECOND_EXTRACT=0.5
MAX_FRAMES_TO_ANALYZE=5
FRAME_RESOLUTION=(1024,1024)
